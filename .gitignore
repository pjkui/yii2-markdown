# ===== 操作系统 =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== 编辑器 / IDE =====
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# ===== 依赖目录 =====
node_modules/
vendor/

# ===== Composer =====
# 作为 Yii2 扩展包，不提交 lock 文件，由使用方自行锁定版本
composer.lock
composer.phar

# ===== npm / Jest / Playwright =====
# 与 composer 策略一致，不提交 npm lock
package-lock.json
npm-debug.log*
.jest-cache/
playwright-report/
playwright/.cache/
test-results/

# ===== PHPUnit / 测试产物 =====
.phpunit.cache/
.phpunit.result.cache
tests/runtime/
tests/_output/
coverage/
*.log

# ===== Examples 运行时产物 =====
examples/assets/
# 保留 uploads 目录下的防护文件（.htaccess/index.html），忽略所有上传内容
examples/uploads/*
!examples/uploads/.htaccess
!examples/uploads/index.html

# ===== 其他 =====
.env
.env.local

# ===== 本地临时文件（截图、playwright-cli 产物）=====
*.png
*.yaml
*.yml
!.github/workflows/*.yml
!playwright.config.js
.playwright-cli/
.codebuddy/
CODEBUDDY.md
examples/CODEBUDDY.md
