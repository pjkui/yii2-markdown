# ===== Composer =====
# 作为 Yii2 扩展包，不提交 lock 文件，由使用方自行锁定版本
composer.lock
composer.phar

# ===== PHPUnit / 测试产物 =====
.phpunit.cache/
.phpunit.result.cache
tests/runtime/
tests/_output/
coverage/
*.log

# ===== Examples 运行时产物 =====
examples/assets/
# 保留 uploads 目录下的防护文件（.htaccess/index.html），忽略所有上传内容
examples/uploads/*
!examples/uploads/.htaccess
!examples/uploads/index.html

# ===== 其他 =====
.env
.env.local
