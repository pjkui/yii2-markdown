# 禁止执行任何脚本，只允许静态文件被读取
# Apache 2.4
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php|phtml|phar|pl|py|jsp|asp|sh|cgi)$">
        Require all denied
    </FilesMatch>
</IfModule>
# Apache 2.2
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|phtml|phar|pl|py|jsp|asp|sh|cgi)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# 关闭目录索引
Options -Indexes

# 禁止把上传文件按可执行 MIME 返回
<IfModule mod_mime.c>
    RemoveHandler .php .phtml .phar
    RemoveType .php .phtml .phar
    AddType application/octet-stream .php .phtml .phar
</IfModule>
