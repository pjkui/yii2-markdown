{
    "name": "pjkui/yii2-markdown",
    "description": "Markdown editor for Yii2",
    "type": "yii2-extension",
    "keywords": ["yii2","extension"],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Quinn Pan",
            "email": "pjkui@qq.com"
        }
    ],
    "require": {
        "yiisoft/yii2": "~2.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0",
        "yidas/yii2-bower-asset": "*"
    },
    "autoload": {
        "psr-4": {
            "pjkui\\markdown\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "pjkui\\markdown\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "demo": [
            "Composer\\Config::disableProcessTimeout",
            "@putenv YII2_MARKDOWN_DEMO=1",
            "php -S 127.0.0.1:8080 -t examples examples/router.php"
        ]
    },
    "archive": {
        "exclude": [
            "/examples",
            "/tests",
            "/docs",
            "/.gitignore",
            "/.gitattributes",
            "/phpunit.xml.dist"
        ]
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
