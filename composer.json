{
    "name": "pjkui/yii2-markdown",
    "description": "Markdown editor for Yii2",
    "type": "yii2-extension",
    "keywords": ["yii2","extension"],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Quinn Pan",
            "email": "pjkui@qq.com"
        }
    ],
    "require": {
        "yiisoft/yii2": "~2.0.0",
        "yidas/yii2-bower-asset": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "pjkui\\markdown\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "pjkui\\markdown\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
